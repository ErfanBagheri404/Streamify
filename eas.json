{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "image": "sdk-54"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "android": {
        "image": "sdk-54"
      }
    },
    "production-apk": {
      "extends": "preview",
      "android": {
        "buildType": "apk",
        "image": "sdk-54"
      },
      "distribution": "internal",
      "env": {
        "NODE_ENV": "production"
      }
    },
    "debug-apk": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug",
        "image": "sdk-54"
      },
      "distribution": "internal",
      "environment": "development",
      "env": {
        "NODE_ENV": "development"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
